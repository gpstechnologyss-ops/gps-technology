{
  "servers": {
    "asset-aware-mcp": {
      "type": "stdio",
      "command": "C:\\Users\\sivar\\.local\\bin\\uv.exe",
      "args": [
        "tool",
        "run",
        "--python",
        "3.11",
        "--from",
        "asset-aware-mcp==0.7.0",
        "asset-aware-mcp"
      ],
      "env": {
        "LLM_BACKEND": "ollama",
        "OLLAMA_HOST": "http://localhost:11434",
        "OLLAMA_MODEL": "granite4.1:3b",
        "OLLAMA_EMBEDDING_MODEL": "nomic-embed-text",
        "ENABLE_LIGHTRAG": "false",
        "DATA_DIR": "d:\\GPS-TECHNOLOGY\\data",
        "UV_CACHE_DIR": "d:\\GPS-TECHNOLOGY\\data\\.uv-cache",
        "ASSET_AWARE_SUPPRESS_MARKER_OUTPUT": "true",
        "ASSET_AWARE_MARKER_OUTPUT_LOG": "d:\\GPS-TECHNOLOGY\\data\\logs\\marker.log",
        "ASSET_AWARE_MCP_TEXT_RESPONSE_CHARS": "12000",
        "ASSET_AWARE_MCP_IMAGE_RESPONSE_CHARS": "750000",
        "ASSET_AWARE_TABLE_STARTUP_LOAD_MAX_BYTES": "20971520",
        "ASSET_AWARE_SECTION_TREE_LOAD_MAX_BYTES": "20971520",
